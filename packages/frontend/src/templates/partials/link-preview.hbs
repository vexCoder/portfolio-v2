{{#if og.title}}
<a href="{{og.url}}" target="_blank" rel="noopener noreferrer" class="block no-underline my-2">
  <div class="border border-border rounded-lg overflow-hidden flex items-stretch hover:border-border-strong transition-colors">
    {{#if og.image}}
    <div class="w-[120px] min-h-[80px] flex-shrink-0 bg-bg-soft border-r border-border overflow-hidden max-md:hidden">
      <img src="{{og.image}}" alt="" class="w-full h-full object-cover" loading="lazy">
    </div>
    {{/if}}
    <div class="px-3.5 py-2.5 min-w-0 flex-1">
      <div class="text-[13px] font-semibold text-fg truncate">{{og.title}}</div>
      {{#if og.description}}
      <div class="text-[11px] text-muted mt-0.5 line-clamp-2">{{og.description}}</div>
      {{/if}}
      <div class="text-[10px] text-muted mt-1 flex items-center gap-1">
        {{#if og.favicon}}
        <img src="{{og.favicon}}" class="w-3 h-3" alt="" loading="lazy" onerror="this.style.display='none'">
        {{/if}}
        {{og.domain}}
      </div>
    </div>
  </div>
</a>
{{else}}
<a href="{{url}}" target="_blank" rel="noopener noreferrer">{{url}}</a>
{{/if}}
