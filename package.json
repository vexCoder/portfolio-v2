{
  "name": "portfolio-v2",
  "private": true,
  "scripts": {
    "dev": "pnpm run dev:css & pnpm run dev:server",
    "dev:css": "pnpm --filter @portfolio/frontend build:css -- --watch",
    "dev:server": "pnpm --filter @portfolio/server dev",
    "build": "pnpm run build:css && pnpm run build:server",
    "build:css": "pnpm --filter @portfolio/frontend build:css",
    "build:server": "pnpm --filter @portfolio/server build",
    "build:artifacts": "tsx scripts/build.ts artifacts",
    "deploy": "tsx scripts/build.ts artifacts && node ./artifacts/server.js",
    "upload": "tsx scripts/upload.ts"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0"
  }
}
